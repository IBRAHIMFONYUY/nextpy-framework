from nextpy.psx import component, psx, useState

@component
def SimpleTest(props=None):
    [name, setName] = useState('NextPy')
    
    return (
        <div className="p-4 bg-blue-500 text-white">
            <h1>Hello {name}!</h1>
            <p>This is a simple test</p>
        </div>
    )

default = SimpleTest
